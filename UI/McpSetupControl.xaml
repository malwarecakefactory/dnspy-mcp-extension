<UserControl x:Class="dnSpy.Extension.MalwareMCP.McpSetupControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
	<Grid Margin="10">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<TextBlock Text="MCP Server Setup" FontSize="16" FontWeight="Bold" />
		<TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,8,0,12"
			Text="This window helps you register dnSpy with Claude Code and explains that folder permissions must be granted in Claude itself, not in dnSpy." />

		<TextBlock Grid.Row="2" FontWeight="Bold" Text="Register your dnSpy MCP server:" />

		<Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,6,0,0">
			<StackPanel>
				<TextBlock Text="Run this on the Claude host:" FontWeight="SemiBold" />
				<TextBox x:Name="CommandTextBox" FontFamily="Consolas" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="70" Margin="0,6,0,0" />
				<Button x:Name="CommandCopyButtonField" Content="Copy command" Width="130" HorizontalAlignment="Left" Margin="0,8,0,0" Click="CopyCommand_Click" />
			</StackPanel>
		</Border>

		<Border Grid.Row="4" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,16,0,0">
			<StackPanel>
				<TextBlock Text="Claude config example:" FontWeight="SemiBold" />
				<TextBox x:Name="JsonTextBox" FontFamily="Consolas" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="140" Margin="0,6,0,0" />
				<Button Content="Copy JSON" Width="130" HorizontalAlignment="Left" Margin="0,8,0,0" Click="CopyJson_Click" />
				<TextBlock x:Name="HostInfoTextBlock" TextWrapping="Wrap" Margin="0,12,0,0" />
				<TextBlock TextWrapping="Wrap" Margin="0,6,0,0"
					Text="If Claude asks for folder access, grant the permission in the Claude client or config file. dnSpy cannot directly add client-side permissions." />
			</StackPanel>
		</Border>
	</Grid>
</UserControl>
